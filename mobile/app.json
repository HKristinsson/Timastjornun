{
  "expo": {
    "name": "Tímaverk",
    "slug": "timaverk",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "timaverk",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#2563eb"
    },
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "is.reir.timaverk",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Appið notar staðsetningu til að staðfesta að þú sért á vinnustað við tímaskráningu.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Appið fylgist með staðsetningu meðan þú ert innskráð(ur) til að staðfesta veru á vinnustað.",
        "UIBackgroundModes": ["location", "fetch"]
      }
    },
    "android": {
      "package": "is.reir.timaverk",
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION"
      ]
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Appið fylgist með staðsetningu meðan þú ert innskráð(ur) til að staðfesta veru á vinnustað.",
          "isAndroidBackgroundLocationEnabled": true,
          "isAndroidForegroundServiceEnabled": true
        }
      ]
    ]
  }
}
