# Afritaðu í .env.local og fylltu út úr Supabase verkefninu þínu
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-PUBLISHABLE-OR-ANON-KEY

# --- Póstgátt (mail gateway) — aðeins server-side, ALDREI í kliént ---
# Service role lykill (Settings -> API -> service_role). Notaður af inbound webhook.
SUPABASE_SERVICE_ROLE_KEY=

# Mailgun (inbound póstur + útsending síðar)
MAILGUN_API_KEY=
MAILGUN_WEBHOOK_SIGNING_KEY=
MAILGUN_DOMAIN=

# Framtíð: beining á Microsoft 365 fyrir hóp 1 (sjá MAILGATEWAY.md)
MICROSOFT_ROUTING_TARGET=
